<?xml version="1.0"?>
<cepRules>


	<!-- 1) New Order -> Pending (maps all order-level custom fields) -->
	<cepRule id="1" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q6331"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Order - $$loyalty_Name_value$$</name>
					<assignee>ops@emojot.com</assignee>
					<type>New Order</type>
					<priority>P3</priority>
					<status>Pending</status>
					<description>
						Pizza order created.
						Customer: $$loyalty_Name_value$$
						Phone: $$loyalty_Telephone_value$$
						Items: $$orderItems_value$$
					</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$ </value></field>
						<field><key>phoneNumber</key><value>$$loyalty_Telephone_value$$</value></field>
						<field><key>email</key><value>$$loyalty_Email_value$$</value></field>
						<field><key>deliveryAddress</key><value>$$deliveryAddress_value$$</value></field>
						<field><key>orderItems</key><value>$$orderItems_value$$</value></field>
						<field><key>pizzaSize</key><value>$$pizzaSize_value$$</value></field>
						<field><key>crust</key><value>$$crust_value$$</value></field>
						<field><key>paymentMethod</key><value>$$paymentMethod_value$$</value></field>
						<field><key>paymentStatus</key><value>$$paymentStatus_value$$</value></field>
						<field><key>totalAmount</key><value>$$totalAmount_value$$</value></field>
						<field><key>deliveryTime</key><value>$$deliveryTime_value$$</value></field>
						<field><key>deliveryPartner</key><value>$$deliveryPartner_value$$</value></field>
						<field><key>trackingURL</key><value>$$trackingURL_value$$</value></field>
						<field><key>issues</key><value>$$issues_value$$</value></field>
						<field><key>resolution</key><value>$$resolution_value$$</value></field>
						<field><key>feedback</key><value>$$feedback_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 2) Confirmed (customer notifications + payment validation intent) -->
	<cepRule id="2" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_confirmed"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Confirmed - $$loyalty_Name_value$$</name>
					<assignee>ops@emojot.com</assignee>
					<type>New Order</type>
					<priority>P3</priority>
					<status>Confirmed</status>
					<description>
						Order payment confirmed.
						Payment Status: $$paymentStatus_value$$
					</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$ </value></field>
						<field><key>phoneNumber</key><value>$$loyalty_Telephone_value$$</value></field>
						<field><key>email</key><value>$$loyalty_Email_value$$</value></field>
						<field><key>paymentStatus</key><value>$$paymentStatus_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>email</type>
				<data>
					<to>$$loyalty_Email_value$$</to>
					<subject>PizzaHut Order Confirmed</subject>
					<bodyType>html</bodyType>
					<body><![CDATA[
<p>Hello $$loyalty_Name_value$$,</p>
<p>Your order has been confirmed.</p>
]]></body>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>sms</type>
				<data>
					<smsType>smsbody</smsType>
						<smsTo>$$loyalty_Telephone_value$$</smsTo>
					<smsbody>Your PizzaHut order is confirmed.</smsbody>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 3) Preparing (notify kitchen + customer) -->
	<cepRule id="3" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_preparing"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Preparing - $$loyalty_Name_value$$</name>
					<assignee>kitchen@emojot.com</assignee>
					<type>New Order</type>
					<priority>P3</priority>
					<status>Preparing</status>
					<description>Order moved to kitchen preparation.</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>orderItems</key><value>$$orderItems_value$$</value></field>
						<field><key>pizzaSize</key><value>$$pizzaSize_value$$</value></field>
						<field><key>crust</key><value>$$crust_value$$</value></field>
						<field><key>specialInstructions</key><value>$$specialInstructions_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>email</type>
				<data>
					<to>kitchen@emojot.com</to>
					<subject>Kitchen Notification - Preparing</subject>
					<bodyType>html</bodyType>
					<body><![CDATA[
<p>Prepare order for $$loyalty_Name_value$$.</p>
<p>Items: $$orderItems_value$$</p>
]]></body>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>sms</type>
				<data>
					<smsType>smsbody</smsType>
					<smsTo>$$loyalty_Telephone_value$$</smsTo>
					<smsbody>Your order is now being prepared.</smsbody>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 4) Ready for Pickup (customer notifications) -->
	<cepRule id="4" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_ready"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Ready - $$loyalty_Name_value$$ </name>
					<assignee>ops@emojot.com</assignee>
					<type>New Order</type>
					<priority>P3</priority>
					<status>Ready</status>
					<description>Order is ready for pickup/delivery handoff.</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$ </value></field>
						<field><key>phoneNumber</key><value>$$loyalty_Telephone_value$$</value></field>
						<field><key>email</key><value>$$loyalty_Email_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>email</type>
				<data>
						<to>$$loyalty_Email_value$$</to>
						<subject>PizzaHut Order Ready</subject>
						<bodyType>html</bodyType>
						<body><![CDATA[
<p>Hello $$loyalty_Name_value$$, your order is ready.</p>
]]></body>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>sms</type>
				<data>
					<smsType>smsbody</smsType>
						<smsTo>$$loyalty_Telephone_value$$</smsTo>
					<smsbody>Your order is ready for pickup.</smsbody>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 5) Out for Delivery -->
	<cepRule id="5" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_out_for_delivery"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Out for Delivery - $$loyalty_Name_value$$</name>
					<assignee>delivery@emojot.com</assignee>
					<type>New Order</type>
					<priority>P3</priority>
					<status>Out for Delivery</status>
					<description>
						Order dispatched for delivery.
						Tracking: $$trackingURL_value$$
					</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>deliveryPartner</key><value>$$deliveryPartner_value$$</value></field>
						<field><key>trackingURL</key><value>$$trackingURL_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>email</type>
				<data>
						<to>$$loyalty_Email_value$$</to>
					<subject>PizzaHut Order Out for Delivery</subject>
					<bodyType>html</bodyType>
					<body><![CDATA[
<p>Your order is on the way.</p>
<p>Tracking: $$trackingURL_value$$</p>
]]></body>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 6) Delivered (confirmation + feedback request) -->
	<cepRule id="6" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_delivered"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Delivered - $$loyalty_Name_value$$</name>
					<assignee>ops@emojot.com</assignee>
					<type>New Order</type>
					<priority>P3</priority>
					<status>Delivered</status>
					<description>Order delivered successfully.</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>feedback</key><value>$$feedback_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>email</type>
				<data>
						<to>$$loyalty_Email_value$$</to>
					<subject>PizzaHut Delivery Confirmation</subject>
					<bodyType>html</bodyType>
					<body><![CDATA[
<p>Your order has been delivered. Thank you!</p>
]]></body>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>email</type>
				<data>
					<to>$$loyalty_Email_value$$</to>
					<subject>PizzaHut Feedback Request</subject>
					<bodyType>html</bodyType>
					<body><![CDATA[
<p>Please share your feedback for your recent order.</p>
]]></body>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 7) Cancelled -->
	<cepRule id="7" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_cancelled"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Cancelled - $$loyalty_Name_value$$</name>
					<assignee>ops@emojot.com</assignee>
					<type>New Order</type>
					<priority>P2</priority>
					<status>Cancelled</status>
					<description>Order cancelled.</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>phoneNumber</key><value>$$loyalty_Telephone_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
			<action>
				<type>email</type>
				<data>
						<to>$$loyalty_Email_value$$</to>
					<subject>PizzaHut Order Cancellation</subject>
					<bodyType>html</bodyType>
					<body><![CDATA[
<p>Your order has been cancelled.</p>
]]></body>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 8) Modification request type -->
	<cepRule id="8" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_modification"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Modification - $$loyalty_Name_value$$</name>
					<assignee>ops@emojot.com</assignee>
					<type>Modification</type>
					<priority>P2</priority>
					<status>Pending</status>
					<description>Customer requested order modification.</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>orderItems</key><value>$$orderItems_value$$</value></field>
						<field><key>specialInstructions</key><value>$$specialInstructions_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 9) Delivery issue type -->
	<cepRule id="9" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_delivery_issue"</value>
			</param>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Delivery Issue - $$loyalty_Name_value$$</name>
					<assignee>delivery@emojot.com</assignee>
					<type>Delivery Issue</type>
					<priority>P1</priority>
					<status>Pending</status>
					<description>
						Delivery issue reported.
						Issue: $$issues_value$$
					</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>phoneNumber</key><value>$$loyalty_Telephone_value$$</value></field>
						<field><key>issues</key><value>$$issues_value$$</value></field>
						<field><key>resolution</key><value>$$resolution_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 10) Complaint type from negative emote -->
	<cepRule id="10" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_feedback"</value>
			</param>
			<joinOperator>and</joinOperator>
			<joinParam>
				<derivedValue>emoteNumericValue</derivedValue>
				<operator>gd</operator>
				<value>0</value>
			</joinParam>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Complaint - $$loyalty_Name_value$$</name>
					<assignee>support@emojot.com</assignee>
					<type>Complaint</type>
					<priority>P1</priority>
					<status>Pending</status>
					<description>
						Negative feedback received.
						Comment: $$feedbackComment_value$$
					</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>phoneNumber</key><value>$$loyalty_Telephone_value$$</value></field>
						<field><key>issues</key><value>$$feedbackComment_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

	<!-- 11) Feedback type from positive emote -->
	<cepRule id="11" timeWindow="10">
		<params>
			<param>
				<name>percepticDrillDown</name>
				<operator>eq</operator>
				<value>"q_pizza_feedback"</value>
			</param>
			<joinOperator>and</joinOperator>
			<joinParam>
				<derivedValue>emoteNumericValue</derivedValue>
				<operator>ld</operator>
				<value>0</value>
			</joinParam>
		</params>
		<engagementActions>
			<action>
				<type>incident</type>
				<data>
					<workflowID>696370c0e02eff840f7d4b2f</workflowID>
					<name>Feedback - $$loyalty_Name_value$$</name>
					<assignee>qa@emojot.com</assignee>
					<type>Feedback</type>
					<priority>P3</priority>
					<status>Pending</status>
					<description>Positive feedback received.</description>
					<customFields>
						<field><key>customerName</key><value>$$loyalty_Name_value$$</value></field>
						<field><key>feedback</key><value>$$feedback_value$$</value></field>
					</customFields>
				</data>
				<validityPeriod>5</validityPeriod>
			</action>
		</engagementActions>
	</cepRule>

</cepRules>
