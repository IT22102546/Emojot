<?xml version="1.0" encoding="UTF-8"?>
<cepRules>
    <!-- ===================== -->
    <!-- UNSATISFIED - EMAIL -->
    <!-- ===================== -->
    <cepRule id="1" timeWindow="5">
        <params>
            <param>
                <name>percepticDrillDown</name>
                <operator>eq</operator>
                <value>"q4057"</value>
            </param>
            <joinOperator>and</joinOperator>
            <joinParam>
                <derivedValue>emoteNumericValue</derivedValue>
                <operator>gd</operator>
                <value>0</value>
            </joinParam>
        </params>
        <engagementActions>
            <action>
                <type>email</type>
                <data>
                    <to>sanjanan@emojot.com,salmanf@emojot.com</to>
                    <subject>Unsatisfied Customer Alert</subject>
                    <bodyType>html</bodyType>
                    <body>
                        <![CDATA[
<p>Dear Team,</p>

<p>An unsatisfied customer response has been received.</p>

<p>
<strong>Name:</strong> $$loyalty_Name_value$$ <br>
<strong>Email:</strong> $$loyalty_Email_value$$ <br>
<strong>Phone:</strong> $$loyalty_Telephone_value$$ <br>
<strong>Response:</strong> $$q4057_emote$$ <br>
<strong>Comment:</strong> $$gp5628_c1_comment_value$$
</p>

<p>Please take immediate action.</p>

<br>
<p>Emojot System</p>
]]>
                    </body>
                </data>
                <validityPeriod>5</validityPeriod>
            </action>
        </engagementActions>
    </cepRule>
